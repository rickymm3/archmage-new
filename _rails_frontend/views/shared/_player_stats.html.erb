<% 
   user = Current.user
   size ||= :large # Default size
   
   # Color schemes
   aff_color_map = {
     'pyromancer' => 'danger',
     'mindweaver' => 'info',
     'geomancer' => 'success',
     'tempest' => 'warning',
     'voidwalker' => 'dark'
   }
   
   affinity_name = user.affinity.name
   bootstrap_color = aff_color_map[affinity_name.downcase] || 'secondary'
   
   # Stats Definition
   all_stats = [
     { label: 'Net Power', value: user.respond_to?(:net_power) ? user.net_power : 0, icon: 'bi-lightning-fill text-warning', format: :number },
     { label: 'Land', value: user.land, icon: 'bi-aspect-ratio text-success', format: :number },
     { label: 'Army Size', value: (user.units.sum(:quantity) || 0) + (user.user_units.sum(:garrison) || 0), icon: 'bi-people-fill text-danger', format: :number },
     { label: 'Magic Power', value: user.magic_power, icon: 'bi-stars text-info', format: :number },
     { label: 'Gold', value: user.gold, icon: 'bi-coin text-warning', format: :number },
     { label: 'Mana', value: user.mana, icon: 'bi-droplet-fill text-primary', format: :number },
     { label: 'Morale', value: "#{user.morale}%", icon: 'bi-emoji-smile text-light', format: :string }
   ]
   
   visible_stats = case size
                   when :small
                     all_stats.first(2) # Just Power & Land
                   when :medium
                     all_stats.first(4) # Power, Land, Army, Magic
                   else
                     all_stats # All
                   end
%>

<div class="card bg-dark border-secondary mb-4 player-stats-widget player-stats-<%= size %>">
  <div class="card-header bg-black bg-opacity-25 border-secondary d-flex justify-content-between align-items-center py-2">
    <h5 class="card-title font-cinzel text-uppercase mb-0 text-white-50 fs-6">
      <i class="bi bi-bar-chart-line me-2"></i>Kingdom Statistics
    </h5>
    <% if size == :large %>
      <span class="badge rounded-pill border border-<%= bootstrap_color %> text-<%= bootstrap_color %> bg-dark">
        <%= affinity_name %> Affinity
      </span>
    <% end %>
  </div>
  
  <div class="card-body p-3">
    <div class="row g-3">
      <% visible_stats.each do |stat| %>
        <div class="<%= size == :large ? 'col-4 col-md-3' : 'col-6' %>">
           <div class="d-flex align-items-center">
             <div class="fs-4 me-3">
               <i class="bi <%= stat[:icon] %>"></i>
             </div>
             <div>
               <div class="small text-muted text-uppercase" style="font-size: 0.65rem;"><%= stat[:label] %></div>
               <div class="fw-bold font-monospace text-white">
                 <% if stat[:format] == :number %>
                   <%= number_with_delimiter(stat[:value]) %>
                 <% else %>
                   <%= stat[:value] %>
                 <% end %>
               </div>
             </div>
           </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
