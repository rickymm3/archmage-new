<div class="h-100 d-flex flex-column overflow-hidden">
  <!-- Mobile Header (Visible < md) -->
  <div class="d-md-none bg-dark border-bottom border-warning p-2 d-flex justify-content-between align-items-center flex-shrink-0">
    <button class="btn btn-outline-warning" type="button" data-bs-toggle="offcanvas" data-bs-target="#townSidebar" aria-controls="townSidebar">
      <i class="bi bi-list me-1"></i>Structures
    </button>
    <span class="text-warning font-cinzel fw-bold">City Management</span>
    <div class="d-flex align-items-center gap-2">
      <div class="badge bg-dark border border-secondary text-end">
        <span class="text-success"><%= current_user.free_land %></span>
        <small class="text-muted ms-1" style="font-size: 0.6rem;">FREE</small>
      </div>
    </div>
  </div>

  <div class="d-flex flex-grow-1 overflow-hidden position-relative">
    
    <!-- Sidebar / Offcanvas -->
    <div class="offcanvas-md offcanvas-start bg-dark text-white border-end border-secondary d-flex flex-column flex-shrink-0" 
         tabindex="-1" 
         id="townSidebar" 
         aria-labelledby="townSidebarLabel" 
         style="width: 280px;">
       
       <!-- Sidebar Header -->
       <div class="p-3 border-bottom border-secondary bg-black bg-opacity-25">
         <div class="d-flex justify-content-between align-items-center mb-3 d-md-none">
            <h5 class="offcanvas-title font-cinzel text-warning" id="townSidebarLabel">Structures</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#townSidebar" aria-label="Close"></button>
         </div>
         
         <h5 class="font-cinzel text-warning mb-3 d-none d-md-block">City Management</h5>
         
         <!-- Stats Block -->
         <div class="d-flex justify-content-between gap-2">
            <div class="d-flex flex-column align-items-center bg-darker border border-secondary p-2 w-100 rounded">
              <span class="text-success fs-5 fw-bold"><%= current_user.free_land %></span>
              <small class="text-muted text-uppercase" style="font-size: 0.6rem;">FREE LAND</small>
            </div>
            <div class="d-flex flex-column align-items-center bg-darker border border-secondary p-2 w-100 rounded">
              <span class="text-info fs-5 fw-bold"><%= current_user.land %></span>
              <small class="text-muted text-uppercase" style="font-size: 0.6rem;">TOTAL</small>
            </div>
         </div>
       </div>
       
       <!-- Structure List -->
       <div class="flex-grow-1 overflow-y-auto custom-scrollbar p-2">
         <div class="d-grid gap-1">
            <% @structures.each do |structure| %>
              <% user_structure = @user_structures[structure.id] %>
              <% 
                 is_active = @selected_structure&.id == structure.id 
                 
                 if structure.level_based?
                   level = user_structure&.level || 0
                   display_text = level > 0 ? "Lvl #{level}" : nil
                 else
                   quantity = user_structure&.quantity || 0
                   display_text = quantity > 0 ? quantity.to_s : nil
                 end
              %>
              
              <%= link_to town_path(structure_id: structure.id), 
                  class: "btn btn-sm d-flex align-items-center justify-content-between text-start #{is_active ? 'btn-secondary border-warning text-warning' : 'btn-dark border-transparent text-muted'} position-relative mb-1",
                  data: { turbo_action: "replace" } do %>
                
                <div class="d-flex align-items-center gap-2 overflow-hidden w-100">
                  <i class="bi bi-bank fs-6 <%= is_active ? 'text-warning' : 'opacity-50' %> user-select-none"></i>
                  <span class="text-truncate fw-bold <%= is_active ? '' : 'fw-normal' %> flex-grow-1"><%= structure.name %></span>
                  
                  <% if display_text %>
                    <span class="badge bg-black bg-opacity-50 text-white border border-secondary rounded-pill ms-2" style="font-size: 0.7rem;"><%= display_text %></span>
                  <% end %>
                </div>
              <% end %>
            <% end %>
         </div>
       </div>
    </div>

    <!-- Main Content Area -->
    <div class="flex-grow-1 overflow-y-auto bg-black p-0 position-relative custom-scrollbar">
      <div class="container-fluid p-3 p-md-4" style="max-width: 1000px;">
        <% if @selected_structure %>
          <%= render "town/details", structure: @selected_structure, user_structures: @user_structures %>
        <% else %>
          <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted" style="min-height: 50vh;">
            <i class="bi bi-bank display-1 mb-3 opacity-25"></i>
            <h4 class="font-cinzel text-secondary">Select a Structure</h4>
            <p class="small text-secondary opacity-75">Choose a building from the list to manage upgrades and production.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
