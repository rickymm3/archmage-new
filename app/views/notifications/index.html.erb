<div class="h-100 d-flex flex-column">
  <div class="container py-4 flex-grow-1 overflow-y-auto">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="font-cinzel text-warning mb-0">Notifications</h2>
      <%= button_to "Mark All Read", mark_all_read_notifications_path, method: :post, class: "btn btn-outline-secondary btn-sm" %>
    </div>
    
    <% if @notifications.empty? %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-bell-slash fs-1 mb-3"></i>
        <p>No new notifications.</p>
      </div>
    <% else %>
      <div class="list-group list-group-flush bg-dark border border-secondary rounded">
        <% @notifications.each do |notif| %>
          <% 
             icon = case notif.category 
               when 'battle' then 'bi-shield-exclamation text-danger'
               when 'resource' then 'bi-coin text-warning'
               else 'bi-info-circle text-info'
             end
             
             bg_class = notif.read? ? 'bg-dark' : 'bg-secondary bg-opacity-25'
          %>
          <%= link_to notification_path(notif), class: "list-group-item list-group-item-action #{bg_class} border-secondary text-white p-3" do %>
            <div class="d-flex w-100 justify-content-between align-items-center mb-1">
              <h5 class="mb-1 font-cinzel">
                <i class="bi <%= icon %> me-2"></i><%= notif.title %>
              </h5>
              <small class="text-muted"><%= time_ago_in_words(notif.created_at) %> ago</small>
            </div>
            <p class="mb-1 text-white-50 small"><%= notif.content %></p>
            <% unless notif.read? %>
              <span class="badge bg-primary rounded-pill position-absolute top-50 end-0 translate-middle-y me-3">New</span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
