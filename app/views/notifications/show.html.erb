<div class="w-100 h-100 overflow-auto">
  <div class="container py-4">
    <div class="mb-3">
      <%= link_to notifications_path, class: "btn btn-outline-secondary btn-sm" do %>
        <i class="bi bi-arrow-left me-1"></i>Back
      <% end %>
    </div>
    
    <div class="card bg-dark border-secondary">
      <div class="card-header border-secondary d-flex justify-content-between align-items-center bg-black bg-opacity-25">
        <h3 class="card-title font-cinzel text-warning mb-0"><%= @notification.title %></h3>
        <span class="badge bg-secondary"><%= @notification.category.humanize %></span>
      </div>
      <div class="card-body">
        <p class="text-white mb-4"><%= @notification.content %></p>
        
        <!-- Full Battle Report -->
        <% if @notification.category == 'battle' && @notification.data['attacker_army'] %>
           <% 
              attacker = @notification.data['attacker'] 
              defender = @notification.data['defender']
              winner = @notification.data['winner']
              # Determine if viewer is attacker or defender or observer
              is_defender = @notification.user == current_user
              # If user is defender, winner='attacker' means Defeat.
              # If user is attacker (if we notified them), winner='attacker' means Victory
              # But ResolutionService currently notifies 'defender' only for results. 
              # Wait, if I add notification for attacker later, I need this logic.
              
              # Logic: 
              # If Viewer is Defender AND Winner is Attacker -> Defeat
              # If Viewer is Defender AND Winner is Defender -> Victory
              
              viewer_won = false
              if is_defender
                 viewer_won = (winner.to_s == 'defender')
              else
                 viewer_won = (winner.to_s == 'attacker')
              end
              
              attacker_army = @notification.data['attacker_army']
              defender_army = @notification.data['defender_army']
           %>
           
           <!-- Outcome Banner -->
           <div class="card bg-black border-<%= viewer_won ? 'success' : 'danger' %> mb-4 shadow rounded-0">
              <div class="card-body text-center py-4">
                 <% if viewer_won %>
                    <h1 class="font-cinzel text-success display-5 fw-bold"><i class="bi bi-trophy me-2"></i>VICTORY</h1>
                 <% else %>
                    <h1 class="font-cinzel text-danger display-5 fw-bold"><i class="bi bi-shield-x me-2"></i>DEFEAT</h1>
                 <% end %>
                 
                 <p class="lead text-white mt-1">
                    Combat against <strong class="text-warning"><%= attacker['username'] == current_user.username ? defender['username'] : attacker['username'] %></strong>
                 </p>
                 
                 <% if @notification.data['land_seized'].to_i > 0 %>
                    <div class="mt-2">
                       <span class="badge <%= viewer_won ? 'bg-success' : 'bg-danger' %> fs-6 p-2 rounded-0 border border-secondary">
                          <i class="bi bi-globe me-2"></i> <%= viewer_won ? '+' : '-' %><%= number_with_delimiter(@notification.data['land_seized']) %> Acres
                       </span>
                    </div>
                 <% end %>
              </div>
           </div>
           
           <!-- Forces Summary -->
           <div class="row g-4 mb-4">
              <!-- Attacker -->
              <div class="col-md-6">
                 <div class="card bg-dark border-secondary h-100">
                    <div class="card-header bg-black border-bottom border-secondary text-center">
                       <h6 class="mb-0 text-white font-cinzel">Attacker: <%= attacker['username'] %></h6>
                    </div>
                    <div class="card-body p-0">
                       <table class="table table-dark table-striped mb-0 small">
                          <thead>
                             <tr>
                                <th class="ps-3">Unit</th>
                                <th class="text-center">Sent</th>
                                <th class="text-center">Lost</th>
                                <th class="text-center pe-3">Alive</th>
                             </tr>
                          </thead>
                          <tbody>
                             <% attacker_army['stacks'].each do |stack| %>
                                <tr>
                                   <td class="ps-3">
                                      <div class="fw-bold"><%= stack['name'] %></div>
                                      <% if stack['hero'] %>
                                         <div class="<%= stack['hero_alive'] ? 'text-warning' : 'text-danger' %> tiny">
                                            <i class="bi bi-star-fill"></i> <%= stack['hero']['name'] %>
                                         </div>
                                      <% end %>
                                   </td>
                                   <td class="text-center text-muted"><%= number_with_delimiter(stack['initial_quantity']) %></td>
                                   <td class="text-center text-danger"><%= stack['lost'].to_i > 0 ? "-#{number_with_delimiter(stack['lost'])}" : "-" %></td>
                                   <td class="text-center text-white fw-bold pe-3"><%= number_with_delimiter(stack['remaining_quantity']) %></td>
                                </tr>
                             <% end %>
                          </tbody>
                       </table>
                    </div>
                 </div>
              </div>
              
              <!-- Defender -->
              <div class="col-md-6">
                 <div class="card bg-dark border-secondary h-100">
                    <div class="card-header bg-black border-bottom border-secondary text-center">
                       <h6 class="mb-0 text-white font-cinzel">Defender: <%= defender['username'] %></h6>
                    </div>
                    <div class="card-body p-0">
                       <table class="table table-dark table-striped mb-0 small">
                          <thead>
                             <tr>
                                <th class="ps-3">Unit</th>
                                <th class="text-center">Start</th>
                                <th class="text-center">Lost</th>
                                <th class="text-center pe-3">Alive</th>
                             </tr>
                          </thead>
                          <tbody>
                             <% defender_army['stacks'].each do |stack| %>
                                <tr>
                                   <td class="ps-3">
                                      <div class="fw-bold"><%= stack['name'] %></div>
                                      <% if stack['hero'] %>
                                         <div class="<%= stack['hero_alive'] ? 'text-warning' : 'text-danger' %> tiny">
                                            <i class="bi bi-star-fill"></i> <%= stack['hero']['name'] %>
                                         </div>
                                      <% end %>
                                   </td>
                                   <td class="text-center text-muted"><%= number_with_delimiter(stack['initial_quantity']) %></td>
                                   <td class="text-center text-danger"><%= stack['lost'].to_i > 0 ? "-#{number_with_delimiter(stack['lost'])}" : "-" %></td>
                                   <td class="text-center text-white fw-bold pe-3"><%= number_with_delimiter(stack['remaining_quantity']) %></td>
                                </tr>
                             <% end %>
                          </tbody>
                       </table>
                    </div>
                 </div>
              </div>
           </div>
        <% end %>

        <!-- Battle Log Renderer -->
        <% if @notification.data && @notification.data['log'] %>
          <h5 class="font-cinzel text-decoration-underline mb-3 text-info">Battle Log</h5>
          <div class="bg-black border border-secondary p-3 rounded font-monospace small" style="max-height: 500px; overflow-y: auto;">
              <% @notification.data['log'].each do |line| %>
                 <% 
                   color_class = if line.include?('VICTORY') 
                                   'text-success fw-bold' 
                                 elsif line.include?('DEFEAT') 
                                   'text-danger fw-bold' 
                                 elsif line.include?('WINNER:')
                                   'text-warning border-top border-bottom py-2 my-2'
                                 elsif line.include?('hits')
                                   'text-light opacity-75'
                                 elsif line.include?('Defender:') || line.include?('Garrison')
                                   'text-info' 
                                 elsif line.include?('Attacker:') || line.include?('Void')
                                   'text-danger' 
                                 elsif line.include?('CRITICAL') || line.include?('SPLASH') || line.include?('HERO')
                                   'text-warning'
                                 elsif line.include?('kills') || line.include?('slaying') || line.include?('WIPED OUT')
                                   'text-danger'
                                 else 
                                   'text-secondary' 
                                 end 
                 %>
                 <div class="<%= color_class %> mb-1"><%= line %></div>
              <% end %>
          </div>
        <% end %>
        
        <% if @notification.data && @notification.data['penalty'] %>
           <div class="alert alert-danger mt-4 bg-transparent border-danger">
              <h6 class="alert-heading font-cinzel text-danger"><i class="bi bi-clipboard-x me-2"></i>Penalties Incurred</h6>
              <hr class="border-danger opacity-50">
              <ul class="mb-0 list-unstyled">
                  <% if @notification.data['penalty']['gold'].to_i > 0 %>
                     <li>Lost <span class="fw-bold"><%= @notification.data['penalty']['gold'] %> Gold</span></li>
                  <% end %>
                  <% if @notification.data['penalty']['morale'].to_i > 0 %>
                     <li>Lost <span class="fw-bold"><%= @notification.data['penalty']['morale'] %> Morale</span></li>
                  <% end %>
              </ul>
           </div>
        <% end %>

      </div>
      <div class="card-footer border-secondary text-end">
         <small class="text-muted">Received <%= @notification.created_at.strftime("%b %d, %H:%M") %></small>
      </div>
    </div>
  </div>
</div>
