<div class="card bg-dark text-white border-secondary mb-4 shadow-sm">
  <% 
     current_morale = @current_morale || current_user.current_morale
     daily_upkeep = @daily_upkeep || current_user.total_army_upkeep
     decay_mult = current_user.morale_penalty_multiplier
     
     # Calculate specific rates
     base_decay_rate = 100.0 / 24.0 # 4.16/hr
     actual_decay_rate = base_decay_rate * decay_mult
     
     # Status Color Logic
     status_color = case current_morale
        when 75..100 then "success"
        when 40..75 then "warning"
        else "danger"
     end
     
     status_text = case current_morale
        when 75..100 then "High"
        when 40..75 then "Unstable"
        else "Critical"
     end
  %>

  <div class="card-body p-3 p-md-4" 
       data-controller="treasury--morale"
       data-treasury--morale-current-value="<%= current_morale %>"
       data-treasury--morale-updated-at-value="<%= Time.current.iso8601 %>"
       data-treasury--morale-decay-rate-value="<%= (100.0 / 1.day.to_i) * decay_mult %>">
     
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
           <h5 class="card-title text-uppercase font-cinzel text-muted mb-1 small fw-bold">Army Morale</h5>
           <div class="d-flex align-items-baseline gap-2">
              <h2 class="display-6 fw-bold text-white mb-0" data-treasury--morale-target="text"><%= current_morale.round(1) %></h2>
              <span class="badge bg-<%= status_color %> bg-opacity-25 text-<%= status_color %> border border-<%= status_color %> small text-uppercase"><%= status_text %></span>
           </div>
        </div>
        <div class="text-end">
           <div class="text-white-50 small text-uppercase fw-bold mb-1">Time until breakdown</div>
           <% if current_morale > 0 && actual_decay_rate > 0 %>
              <% hours_left = (current_morale / actual_decay_rate).round(1) %>
              <div class="h5 font-monospace text-<%= hours_left < 4 ? 'danger' : 'info' %> mb-0">
                 ~<%= hours_left %>h
              </div>
           <% else %>
              <div class="h5 font-monospace text-muted mb-0">--</div>
           <% end %>
        </div>
    </div>

    <!-- Meter -->
    <div class="progress bg-secondary bg-opacity-25 mb-4" style="height: 12px; border-radius: 6px;">
        <div class="progress-bar bg-<%= status_color %> progress-bar-striped progress-bar-animated" 
             role="progressbar" 
             style="width: <%= current_morale %>%;" 
             data-treasury--morale-target="bar"
             aria-valuenow="<%= current_morale %>" 
             aria-valuemin="0" 
             aria-valuemax="100">
        </div>
    </div>
    
    <!-- Stats Grid -->
    <div class="row g-3 small text-white-50 mb-0 border-top border-secondary pt-3">
       <!-- Base Cost -->
       <div class="col-6 col-md-3">
          <div class="text-uppercase fw-bold opacity-75" style="font-size: 0.7rem;">Daily Upkeep</div>
          <div class="text-warning fw-bold fs-6"><%= number_with_delimiter(daily_upkeep) %> <small>gold</small></div>
       </div>
       
       <!-- Current Decay Rate -->
       <div class="col-6 col-md-3">
          <div class="text-uppercase fw-bold opacity-75" style="font-size: 0.7rem;">Decay Rate</div>
          <div class="d-flex align-items-center gap-1">
             <i class="bi bi-graph-down-arrow text-danger"></i>
             <span class="fw-bold text-white"><%= actual_decay_rate.round(1) %></span>
             <span class="opacity-50">/hr</span>
          </div>
       </div>

       <!-- Modifiers -->
       <div class="col-12 col-md-6">
          <div class="text-uppercase fw-bold opacity-75 mb-1" style="font-size: 0.7rem;">Active Modifiers</div>
          <div class="d-flex flex-wrap gap-2">
             <!-- Base Rate -->
             <span class="badge bg-dark border border-secondary text-muted fw-normal">Base: -4.2/hr</span>

             <% if decay_mult > 1.0 %>
               <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">
                  Overcrowded: <%= ((decay_mult - 1.0) * 100).round %>% Faster
               </span>
             <% end %>
             
             <!-- Placeholder for spells -->
             <% active_bonus = current_user.active_spell_bonus(:morale) %>
             <% if active_bonus > 0 %>
                <span class="badge bg-success bg-opacity-10 text-success border border-success">
                   Magic: +<%= active_bonus %>/hr
                </span>
             <% end %>
          </div>
       </div>
    </div>
    
    <!-- Action Buttons (Only if needed) -->
    <% if current_morale < 100 && daily_upkeep > 0 %>
      <div class="mt-4 pt-3 border-top border-secondary">
         <div class="d-flex gap-2">
            <% 
               # Cost Logic
               cost_per_point = daily_upkeep / 100.0
               missing = [100 - current_morale, 0].max
               
               boost_amount = [20, missing].min
               boost_cost = (cost_per_point * boost_amount).ceil
               
               max_cost = (cost_per_point * missing).ceil
            %>

            <% if current_user.gold >= boost_cost && boost_amount > 0 %>
               <%= button_to pay_upkeep_army_path(amount: boost_cost), method: :post, class: "btn btn-sm btn-outline-light flex-fill d-flex align-items-center justify-content-center gap-2" do %>
                  <i class="bi bi-caret-up-fill text-success"></i>
                  Boost (+<%= boost_amount.round %>) <span class="badge bg-dark border border-secondary text-warning ms-1"><%= boost_cost %>g</span>
               <% end %>
            <% end %>
            
            <% if current_user.gold >= max_cost %>
               <%= button_to pay_upkeep_army_path(amount: max_cost), method: :post, class: "btn btn-sm btn-warning flex-fill d-flex align-items-center justify-content-center gap-2 text-dark fw-bold" do %>
                  <i class="bi bi-star-fill"></i>
                  Maixmize <span class="badge bg-black text-warning ms-1"><%= max_cost %>g</span>
               <% end %>
            <% end %>
         </div>
      </div>
    <% end %>

  </div>
</div>
