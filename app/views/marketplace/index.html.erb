<div class="flex-grow-1 overflow-y-scroll w-100" style="min-height: 0;">
  <div class="container py-4">
    <div class="row mb-5 text-center">
      <div class="col-12 col-lg-8 mx-auto">
        <h1 class="display-5 text-white font-cinzel text-uppercase">Resource Market</h1>
        <p class="lead text-white-50">Acquire rare units and spells from across the realms.</p>
        <div class="d-flex justify-content-center gap-3 text-white-50 small font-monospace">
           <span><i class="bi bi-circle-fill text-light opacity-50 me-1"></i>Common</span>
           <span><i class="bi bi-circle-fill text-success opacity-50 me-1"></i>Uncommon</span>
           <span><i class="bi bi-circle-fill text-info opacity-50 me-1"></i>Rare</span>
           <span><i class="bi bi-circle-fill text-warning opacity-50 me-1"></i>Legendary</span>
        </div>
        
        <div class="mt-4">
          <div class="btn-group" role="group">
            <%= link_to "Unit & Spell Market", marketplace_index_path(filter: 'regular'), class: "btn #{@filter == 'regular' ? 'btn-warning' : 'btn-outline-warning'} font-cinzel" %>
            <%= link_to "Hero Tavern", marketplace_index_path(filter: 'heroes'), class: "btn #{@filter == 'heroes' ? 'btn-warning' : 'btn-outline-warning'} font-cinzel" %>
          </div>
        </div>
      </div>
    </div>
    
    <% if @won_listings && @won_listings.any? %>
      <div class="row mb-5">
        <div class="col-12">
          <h4 class="text-warning font-cinzel mb-3 border-bottom border-warning pb-2">Pending Collections</h4>
          <div class="row g-4">
            <% @won_listings.each do |listing| %>
              <div class="col-12 col-md-6 col-lg-4 mb-4">
                <div class="card bg-dark border-warning h-100 shadow-lg position-relative">
                  <div class="card-body text-center">
                     <h5 class="card-title text-warning font-cinzel mb-2"><%= listing.item.name %></h5>
                     <p class="text-white-50 small mb-3">Won for <%= listing.current_price %> <i class="bi bi-coin text-warning"></i></p>
                     <%= button_to "Collect", collect_marketplace_path(listing), method: :post, class: "btn btn-outline-warning w-100 font-cinzel small" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @listings.any? %>
      <div class="row g-4" id="marketplace-listings">
        <% @listings.each do |listing| %>
          <%= render "marketplace/listing_card", listing: listing %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5">
         <i class="bi bi-shop display-1 text-muted opacity-25 mb-3"></i>
         <p class="lead text-muted">The marketplace is currently empty. Check back soon!</p>
      </div>
    <% end %>

  </div>
</div>
