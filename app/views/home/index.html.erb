<div class="flex-grow-1 overflow-y-scroll w-100" style="min-height: 0;">
  <div class="container py-4">
<% if authenticated? %>
  <div class="row">
    <div class="col-md-4 order-md-2 mb-4">
      <%= render "home/notifications" %>
    </div>

    <div class="col-md-8 order-md-1">
      <%= render "shared/player_stats", size: :large %>

      <h3 class="font-cinzel text-warning mb-3">Dominion Overview</h3>

      <div class="row g-3">
        <!-- Town -->
        <div class="col-6 col-md-4">
          <a href="<%= town_path %>" class="text-decoration-none">
            <div class="action-card card-town">
              <i class="bi bi-house-door-fill"></i>
              <h5 class="font-cinzel text-uppercase small mb-1">Town</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Manage Structures</small>
            </div>
          </a>
        </div>

        <!-- Spells -->
        <div class="col-6 col-md-4">
          <a href="<%= spells_path %>" class="text-decoration-none">
            <div class="action-card card-spells">
              <i class="bi bi-lightning-charge-fill"></i>
              <h5 class="font-cinzel text-uppercase small mb-1">Spells</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Research & Cast</small>
            </div>
          </a>
        </div>

        <!-- Recruit -->
        <div class="col-6 col-md-4">
          <a href="<%= recruit_index_path %>" class="text-decoration-none">
            <div class="action-card card-recruit">
              <i class="bi bi-person-plus-fill"></i>
              <h5 class="font-cinzel text-uppercase small mb-1">Recruit</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Train Units</small>
            </div>
          </a>
        </div>

        <!-- Army -->
        <div class="col-6 col-md-4">
          <a href="<%= army_path %>" class="text-decoration-none">
            <div class="action-card card-war">
              <i class="bi bi-shield-shaded"></i>
              <h5 class="font-cinzel text-uppercase small mb-1">Army</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Manage Forces</small>
            </div>
          </a>
        </div>

        <!-- Marketplace -->
        <div class="col-6 col-md-4">
          <a href="<%= marketplace_index_path %>" class="text-decoration-none">
            <div class="action-card">
              <i class="bi bi-cart4 text-success"></i>
              <h5 class="font-cinzel text-uppercase small mb-1">Market</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Trade Resources</small>
            </div>
          </a>
        </div>

        <!-- Hall of Heroes -->
        <div class="col-6 col-md-4">
          <a href="<%= heroes_path %>" class="text-decoration-none">
            <div class="action-card">
              <i class="bi bi-award-fill text-primary"></i>
              <h5 class="font-cinzel text-uppercase small mb-1">Heroes</h5>
              <small class="text-muted" style="font-size: 0.65rem;">hire Legends</small>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="row align-items-center min-vh-75">
    <div class="col-lg-6 text-center text-lg-start">
      <h1 class="display-2 fw-bold text-warning mb-3" style="text-shadow: 2px 2px 4px #000;">Archmage</h1>
      <h2 class="h3 text-light mb-4">The Reincarnation</h2>
      <p class="lead text-muted mb-4">
        Construct your empire. Master the arcane. Dominate the realm.
        <br>
        The ultimate text-based strategy game returns.
      </p>
      <div class="d-grid gap-3 d-md-flex justify-content-md-start">
        <%= link_to "Join the Battle", new_registration_path, class: "btn btn-warning btn-lg px-4 me-md-2 fw-bold" %>
        <%= link_to "Login", new_session_path, class: "btn btn-outline-light btn-lg px-4" %>
      </div>
    </div>
    
    <div class="col-lg-5 offset-lg-1 mt-5 mt-lg-0">
      <%# Login form embedded for quick access %>
      <div class="card bg-dark border-secondary shadow-lg">
        <div class="card-body p-4">
           <h3 class="text-center text-warning mb-4 font-cinzel">Enter the Realm</h3>
           
           <%= render "sessions/form" %>
           
           <div class="mt-3 text-center">
             <%= link_to "Forgot password?", new_password_path, class: "text-muted small text-decoration-none" %>
           </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
  </div>
</div>
