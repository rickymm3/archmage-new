<div class="h-100 d-flex flex-column overflow-hidden container-fluid p-0">
  
  <div class="bg-dark border-bottom border-secondary p-3 d-flex justify-content-between align-items-center">
    <div>
       <span class="text-danger font-cinzel fw-bold border-end border-danger pe-3 me-3 h5 mb-0">
         <i class="bi bi-swords me-2"></i>Battle Arena
       </span>
       <small class="text-warning text-uppercase" style="font-size: 0.7rem;">PVP Combat</small>
    </div>
    
    <div>
       <% if @can_refresh %>
         <%= button_to scout_battles_path, method: :post, class: "btn btn-sm btn-outline-warning text-warning d-flex align-items-center gap-2 font-cinzel" do %>
            <i class="bi bi-eye-fill"></i> Scouting Report
         <% end %>
       <% else %>
         <button class="btn btn-sm btn-dark text-muted border border-secondary" disabled>
           <i class="bi bi-hourglass-split me-1"></i>Scanning...
         </button>
       <% end %>
    </div>
  </div>

  <div class="row g-4 p-4 overflow-y-auto custom-scrollbar m-0">
    <% if @targets.any? %>
      <% @targets.each do |target| %>
        <div class="col-md-6 col-lg-4 col-xl-3">
           <div class="card bg-black border-secondary h-100 shadow-lg glow-hover-danger position-relative overflow-hidden style='transition: transform 0.2s;'">
             <div class="card-header bg-dark border-secondary d-flex justify-content-between align-items-center py-3">
                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger font-cinzel">Rank <%= target['rank'] || '?' %></span>
                <span class="d-flex align-items-center gap-1 text-muted small">
                   <i class="bi bi-clock-history"></i>
                   <%= time_ago_in_words(current_user.last_scouted_at) %>
                </span>
             </div>
             
             <div class="card-body text-center p-4 d-flex flex-column">
                <div class="mb-4 position-relative">
                   <div class="mx-auto rounded-circle d-flex align-items-center justify-content-center bg-dark border border-secondary shadow-inner" style="width: 80px; height: 80px;">
                      <i class="bi bi-person-fill display-5 text-white opacity-50"></i>
                   </div>
                   <div class="position-absolute start-50 translate-middle-x mt-2 badge bg-dark border border-secondary text-white fw-light px-3 py-1 rounded-pill shadow-sm" style="bottom: -15px;">
                      <%= target['name'] %>
                   </div>
                </div>
                
                <div class="mt-3 mb-4">
                   <div class="row g-2 justify-content-center">
                      <div class="col-6">
                         <div class="p-2 border border-secondary rounded bg-dark bg-opacity-50">
                            <small class="text-uppercase text-muted d-block" style="font-size: 0.65rem;">Territory</small>
                            <span class="fw-bold text-white"><%= number_with_delimiter(target['land']) %></span>
                         </div>
                      </div>
                      <div class="col-6">
                         <div class="p-2 border border-secondary rounded bg-dark bg-opacity-50">
                            <small class="text-uppercase text-muted d-block" style="font-size: 0.65rem;">Power Est.</small>
                            <span class="fw-bold text-warning"><%= number_with_delimiter(target['power_estimate']) %></span>
                         </div>
                      </div>
                   </div>
                </div>
                
                <div class="mt-auto">
                    <%= link_to new_battle_path(target_id: target['id']), class: "btn btn-outline-danger w-100 font-cinzel text-uppercase fw-bold d-flex align-items-center justify-content-center gap-2 py-2 group-hover-fill" do %>
                       <i class="bi bi-crosshair fs-5"></i> Prepare Assault
                    <% end %>
                </div>
             </div>
             <div class="card-footer bg-dark border-top border-secondary p-2 text-center">
                 <small class="text-muted fst-italic" style="font-size: 0.7rem;">Last known location...</small>
             </div>
           </div>
        </div>
      <% end %>
    <% else %>
        <div class="col-12 text-center py-5 opacity-50">
           <i class="bi bi-binoculars display-1 mb-3 text-muted"></i>
           <h4 class="font-cinzel text-white">No Enemies Found</h4>
           <p class="text-white-50">Your scouts have not reported any suitable targets nearby.</p>
           <% if @can_refresh %>
             <%= button_to "Refresh Scouting Report", scout_battles_path, method: :post, class: "btn btn-info mt-3" %>
           <% end %>
        </div>
    <% end %>
  </div>
</div>
